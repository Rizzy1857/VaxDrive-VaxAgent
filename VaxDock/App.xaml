<Application x:Class="VaxDrive.VaxDock.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/Dashboard.xaml">
    <Application.Resources>
        <!-- Sleek Dark Blue Theme Colors -->
        <SolidColorBrush x:Key="BgDarkBrush" Color="#0B132B"/>
        <SolidColorBrush x:Key="BgLighterBrush" Color="#1C2541"/>
        <SolidColorBrush x:Key="AccentCyanBrush" Color="#5BC0BE"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#3A506B"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#A9A9A9"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A506B"/>

        <!-- Typography -->
        <Style x:Key="HeadingStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="SubHeadingStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Global Window Style -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BgDarkBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
        </Style>

        <!-- Global Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgLighterBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentCyanBrush}"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentCyanBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource BgDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global TextBox / PasswordBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgLighterBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextLightBrush}"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource BgLighterBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextLightBrush}"/>
        </Style>

        <!-- Global ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgLighterBrush}"/>
            <Setter Property="Foreground" Value="Black"/> <!-- Text inside dropdown is usually hard to style purely without deep templates, defaulting to black for combo text to be safe or light depending on system -->
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- Global DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgDarkBrush}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="RowBackground" Value="{StaticResource BgLighterBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Application.Resources>
</Application>
