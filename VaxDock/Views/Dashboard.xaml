<Window x:Class="VaxDrive.VaxDock.Views.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VaxDock - Threat Intelligence Center" Height="700" Width="1000"
        Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource TextLightBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header & Cadence -->
            <RowDefinition Height="Auto"/> <!-- API & Sync Row -->
            <RowDefinition Height="Auto"/> <!-- Filters & Metrics Row -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
        </Grid.RowDefinitions>
        
        <!-- HEADER -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="VaxDock Command Center" Style="{StaticResource HeadingStyle}"/>
            <TextBlock x:Name="CadenceAlertText" Foreground="#FF6B6B" FontWeight="Bold" Margin="0,0,0,10" Visibility="Collapsed"/>
        </StackPanel>

        <!-- API & SYNC ROW -->
        <Border Grid.Row="1" Background="{StaticResource BgLighterBrush}" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="NVD API Key:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <PasswordBox x:Name="NvdApiKeyBox" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <Button Grid.Column="2" Content="Sync NVD Definitions" Click="SyncNvd_Click" Width="180"/>
                <Button Grid.Column="3" Content="View Definitions" Click="ViewDefinitions_Click" Width="150"/>
                <Button Grid.Column="4" Content="Prepare Drive" Click="PrepareDrive_Click" Width="150" Background="{StaticResource AccentCyanBrush}" Foreground="{StaticResource BgDarkBrush}"/>
            </Grid>
        </Border>

        <!-- FILTERS & METRICS ROW -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                <TextBlock Text="Filter Device ID:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="FilterDeviceBox" Width="120" TextChanged="Filter_Changed"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Min Severity:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="FilterSeverityCombo" Width="100" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="Critical"/>
                    <ComboBoxItem Content="High"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Total Devices: " FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TotalDevicesText" Foreground="{StaticResource TextLightBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                <Button Content="Export Findings CSV" Click="Export_Click" Width="150"/>
            </StackPanel>
        </Grid>

        <!-- DATAGRID -->
        <DataGrid x:Name="DevicesGrid" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" MouseDoubleClick="DevicesGrid_MouseDoubleClick" RowHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Device ID" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Last Seen (UTC)" Binding="{Binding LastSeen}" Width="Auto"/>
                <DataGridTextColumn Header="Critical Findings" Binding="{Binding CriticalCount}" Width="Auto"/>
                <DataGridTextColumn Header="High Findings" Binding="{Binding HighCount}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
