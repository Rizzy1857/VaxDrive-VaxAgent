<Window x:Class="VaxDrive.VaxDock.Views.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VaxDrive.VaxDock.Views"
        Title="VaxDock - Threat Intelligence Center" Height="700" Width="1000"
        Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource TextLightBrush}">
    <Window.Resources>
        <Style x:Key="SegmentedButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="Transparent" CornerRadius="4" Padding="12,4" Cursor="Hand" Margin="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentCyanBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource BgDarkBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- Subtle Animated "PixelBlast" Inspired Background -->
        <Grid x:Name="AnimatedBackground" IsHitTestVisible="False">
            <Rectangle Fill="{StaticResource BgDarkBrush}" />
            
            <!-- Floating Purple Orb -->
            <Rectangle Opacity="0.15">
                <Rectangle.Fill>
                    <RadialGradientBrush x:Name="Blob1" Center="0.2,0.2" GradientOrigin="0.2,0.2" RadiusX="0.8" RadiusY="0.8">
                        <GradientStop Color="#B497CF" Offset="0" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </RadialGradientBrush>
                </Rectangle.Fill>
                <Rectangle.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <PointAnimation Storyboard.TargetName="Blob1" Storyboard.TargetProperty="Center" From="0.1,0.1" To="0.9,0.9" Duration="0:0:25" AutoReverse="True" />
                                <PointAnimation Storyboard.TargetName="Blob1" Storyboard.TargetProperty="GradientOrigin" From="0.1,0.1" To="0.9,0.9" Duration="0:0:25" AutoReverse="True" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Rectangle.Triggers>
            </Rectangle>

            <!-- Floating Blue Orb -->
            <Rectangle Opacity="0.10">
                <Rectangle.Fill>
                    <RadialGradientBrush x:Name="Blob2" Center="0.8,0.3" GradientOrigin="0.8,0.3" RadiusX="0.6" RadiusY="0.6">
                        <GradientStop Color="#0072FF" Offset="0" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </RadialGradientBrush>
                </Rectangle.Fill>
                <Rectangle.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <PointAnimation Storyboard.TargetName="Blob2" Storyboard.TargetProperty="Center" From="0.8,0.3" To="0.2,0.8" Duration="0:0:20" AutoReverse="True" />
                                <PointAnimation Storyboard.TargetName="Blob2" Storyboard.TargetProperty="GradientOrigin" From="0.8,0.3" To="0.2,0.8" Duration="0:0:20" AutoReverse="True" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Rectangle.Triggers>
            </Rectangle>

            <!-- Subtle Pixel Grid Overlay -->
            <Rectangle Opacity="0.04" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <VisualBrush TileMode="Tile" Viewport="0,0,6,6" ViewportUnits="Absolute">
                        <VisualBrush.Visual>
                            <Ellipse Width="3" Height="3" Fill="White" Margin="1.5"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- Main Content -->
        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header & Cadence -->
            <RowDefinition Height="Auto"/> <!-- API & Sync Row -->
            <RowDefinition Height="Auto"/> <!-- Filters & Metrics Row -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
        </Grid.RowDefinitions>
        
        <!-- HEADER -->
        <StackPanel Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="VaxDock Command Center" Style="{StaticResource HeadingStyle}" Margin="0,0,0,10"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Devices at Risk: " FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Foreground="#FF6B6B"/>
                    <TextBlock x:Name="DevicesAtRiskText" Text="-" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextLightBrush}"/>
                </StackPanel>
            </Grid>
            
            <Border x:Name="CadenceAlertBanner" Background="#33FF6B6B" BorderBrush="#FF6B6B" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,15" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="CadenceAlertTitle" Foreground="#FF6B6B" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                        <TextBlock x:Name="CadenceAlertDevices" Foreground="{StaticResource TextLightBrush}" FontSize="12"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Dismiss" Width="80" Height="25" Click="DismissCadenceAlert_Click" Background="Transparent" Foreground="#FF6B6B" BorderBrush="#FF6B6B" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- ACTIONS & API ROW -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left side: API Key -->
            <Border Grid.Column="0" Background="{StaticResource BgLighterBrush}" CornerRadius="6" Padding="20" Margin="0,0,20,0" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="API Configuration" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="{StaticResource AccentCyanBrush}"/>
                    <TextBlock Text="NVD API Key:" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="NvdApiKeyBox" Margin="0,0,0,15" Height="30"/>
                    <TextBlock Text="Provide an NVD API key to bypass rate limits when syncing definition packs. You only need to provide this when performing a Sync action." TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}"/>
                    
                    <!-- Progress UI (Hidden by Default) -->
                    <ProgressBar x:Name="SyncProgressBar" Visibility="Collapsed" IsIndeterminate="True" Height="10" Margin="0,20,0,10"/>
                    <TextBlock x:Name="SyncStatusText" Text="" Foreground="#FFDF4C" TextWrapping="Wrap" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Right side: CardSwap Control -->
            <local:CardSwapControl x:Name="ActionCards" Grid.Column="1" 
                                   SyncClicked="ActionCards_SyncClicked" 
                                   ViewClicked="ActionCards_ViewClicked" 
                                   PrepareClicked="ActionCards_PrepareClicked" />
        </Grid>

        <!-- FILTERS & METRICS ROW -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                <TextBlock Text="Filter Device ID:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="FilterDeviceBox" Width="120" TextChanged="Filter_Changed"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Min Severity:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Border Background="{StaticResource BgLighterBrush}" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="2">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="FilterSeverityAll" Content="All" IsChecked="True" Style="{StaticResource SegmentedButtonStyle}" Checked="Filter_Changed" GroupName="SeverityFilter"/>
                        <RadioButton x:Name="FilterSeverityCritical" Content="Critical" Style="{StaticResource SegmentedButtonStyle}" Checked="Filter_Changed" GroupName="SeverityFilter"/>
                        <RadioButton x:Name="FilterSeverityHigh" Content="High" Style="{StaticResource SegmentedButtonStyle}" Checked="Filter_Changed" GroupName="SeverityFilter"/>
                        <RadioButton x:Name="FilterSeverityMedium" Content="Medium" Style="{StaticResource SegmentedButtonStyle}" Checked="Filter_Changed" GroupName="SeverityFilter"/>
                        <RadioButton x:Name="FilterSeverityLow" Content="Low" Style="{StaticResource SegmentedButtonStyle}" Checked="Filter_Changed" GroupName="SeverityFilter"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Total Devices: " FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TotalDevicesText" Foreground="{StaticResource TextLightBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                <Button Content="Export Findings CSV" Click="Export_Click" Width="150"/>
            </StackPanel>
        </Grid>

        <!-- DATAGRID -->
        <DataGrid x:Name="DevicesGrid" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" MouseDoubleClick="DevicesGrid_MouseDoubleClick" RowHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Device ID" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Last Seen (UTC)" Binding="{Binding LastSeen}" Width="Auto"/>
                <DataGridTextColumn Header="Criticality" Binding="{Binding AssetCriticality}" Width="Auto"/>
                <DataGridTextColumn Header="Critical Findings" Binding="{Binding CriticalCount}" Width="Auto"/>
                <DataGridTextColumn Header="High Findings" Binding="{Binding HighCount}" Width="Auto"/>
                <DataGridTextColumn Header="Medium Findings" Binding="{Binding MediumCount}" Width="Auto"/>
                <DataGridTextColumn Header="Low Findings" Binding="{Binding LowCount}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
    </Grid>
</Window>
