<Window x:Class="VaxDrive.VaxDock.Views.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VaxDock Dashboard" Height="600" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0">
            <TextBlock Text="VaxDrive Dashboard" Style="{StaticResource HeadingStyle}"/>
            <TextBlock x:Name="CadenceAlertText" Foreground="Red" FontWeight="Bold" Margin="0,0,0,10" Visibility="Collapsed"/>
            <Grid Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="Total Devices: " FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TotalDevicesText" Margin="0,0,20,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="Export Findings CSV" Click="Export_Click" Width="130" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>

        <DataGrid x:Name="DevicesGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" MouseDoubleClick="DevicesGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Device ID" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Last Seen (UTC)" Binding="{Binding LastSeen}" Width="Auto"/>
                <DataGridTextColumn Header="Critical Findings" Binding="{Binding CriticalCount}" Width="Auto"/>
                <DataGridTextColumn Header="High Findings" Binding="{Binding HighCount}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
