<Window x:Class="VaxDrive.VaxDock.Views.SyncedDefinitions"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Synced NVD Definitions" Height="550" Width="600"
        Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource TextLightBrush}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <CubicEase x:Key="CubicEaseOut" EasingMode="EaseOut"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Latest Synced NVD Definitions" Style="{StaticResource HeadingStyle}" Grid.Row="0"/>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Pack Version: " FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}"/>
            <TextBlock x:Name="PackVersionText" Margin="0,0,20,0"/>
            <TextBlock Text="Generated (UTC): " FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}"/>
            <TextBlock x:Name="GeneratedText" Margin="0,0,20,0"/>
            <TextBlock Text="Rules Loaded: " FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}"/>
            <TextBlock x:Name="RulesCountText"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <ScrollViewer x:Name="ListScrollViewer" FocusVisualStyle="{x:Null}" BorderThickness="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden" ScrollChanged="RulesList_ScrollChanged">
                <ItemsControl x:Name="RulesList" FocusVisualStyle="{x:Null}" BorderThickness="0">
                    <!-- Standard StackPanel, but VirtualizingStackPanel could be used if wrapped in a ListBox -->
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2F293A" CornerRadius="8" Padding="16" Margin="0,0,0,16" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.7" ScaleY="0.7"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Border.Opacity>0</Border.Opacity>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" />
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2" EasingFunction="{StaticResource CubicEaseOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2" EasingFunction="{StaticResource CubicEaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Id}" Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Component}" Foreground="#AAAAAA" FontSize="14" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Severity}" Foreground="#FFDF4C" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right" Margin="0,0,0,8"/>
                                        <Border Background="#1AFFFFFF" CornerRadius="4" Padding="8,4" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Status}" Foreground="White" FontSize="12"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Top Gradient Overlay -->
            <Border x:Name="TopGradient" VerticalAlignment="Top" Height="50" IsHitTestVisible="False" Opacity="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0B132B" Offset="0"/>
                        <GradientStop Color="#000B132B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Bottom Gradient Overlay -->
            <Border x:Name="BottomGradient" VerticalAlignment="Bottom" Height="80" IsHitTestVisible="False" Opacity="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                        <GradientStop Color="#0B132B" Offset="0"/>
                        <GradientStop Color="#000B132B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
    </Grid>
</Window>
