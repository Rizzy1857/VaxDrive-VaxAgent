<Window x:Class="VaxDrive.VaxDock.Views.DeviceDetail"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VaxDrive.VaxDock.Views"
        Title="Device Details" Height="600" Width="900"
        Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource TextLightBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0">
            <TextBlock Text="Device Findings" Style="{StaticResource HeadingStyle}"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="Device ID: " FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DeviceIdText" Margin="0,0,20,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <Button Content="Export CSV" Click="ExportCsv_Click" Width="100" Margin="0,0,10,0"/>
                    <Button Content="Export PDF" Click="ExportPdf_Click" Width="100"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <GroupBox Header="Assessment Status &amp; Metadata" Grid.Row="1" Margin="0,0,0,15" Foreground="{StaticResource TextLightBrush}" BorderBrush="{StaticResource AccentCyanBrush}">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Labels -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Last Scan:" FontWeight="Bold" Margin="0,0,10,5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Definitions Age:" FontWeight="Bold" Margin="0,0,10,5"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Scan Completeness:" FontWeight="Bold" Margin="0,0,10,5"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Asset Criticality:" FontWeight="Bold" Margin="0,0,10,5"/>
                
                <!-- Row 1: Values -->
                <TextBlock x:Name="LastScanText" Grid.Row="1" Grid.Column="0" Text="Unknown" VerticalAlignment="Center"/>
                <TextBlock x:Name="DefinitionsAgeText" Grid.Row="1" Grid.Column="1" Text="Unknown" VerticalAlignment="Center"/>
                <TextBlock x:Name="CompletenessText" Grid.Row="1" Grid.Column="2" Text="Unknown" VerticalAlignment="Center"/>
                
                <ComboBox x:Name="CriticalityCombo" Grid.Row="1" Grid.Column="3" Width="130" HorizontalAlignment="Left" SelectionChanged="Criticality_Changed" VerticalAlignment="Center">
                    <ComboBoxItem Content="CRITICAL"/>
                    <ComboBoxItem Content="HIGH"/>
                    <ComboBoxItem Content="MEDIUM"/>
                    <ComboBoxItem Content="LOW"/>
                    <ComboBoxItem Content="UNCLASSIFIED"/>
                </ComboBox>

                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <StackPanel Margin="0,0,20,0" VerticalAlignment="Center">
                        <TextBlock Text="Overall Status" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="AssessmentStatusText" Text="UNKNOWN" FontWeight="Bold" FontSize="16" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <Button Content="Suppress Selected" Click="Suppress_Click" Width="140" Height="30" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <DataGrid x:Name="FindingsGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" MouseDoubleClick="FindingsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="CVE ID" Binding="{Binding CveId}" Width="150"/>
                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100"/>
                <DataGridTextColumn Header="Component" Binding="{Binding Component}" Width="200"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Suppressed" Binding="{Binding Suppressed}" Width="80"/>
                <DataGridTextColumn Header="Ignored Until" Binding="{Binding IgnoredUntil}" Width="150"/>
                <DataGridTextColumn Header="Resolved At" Binding="{Binding ResolvedAt}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
