# VaxDrive Configuration Environment Variables
# Copy this file to .env and supply the actual keys during CI build.
# NEVER commit the actual .env file to version control.

# The pre-shared AES-256-GCM encryption key used for securing the .vax scan results.
# Must be exactly 32 bytes, base64 encoded.
VAXDRIVE_MASTER_KEY=3YNKvSxhwpIil3mtHyGzbI/C1MGuETOXm8aC7ivQItg=

# The pre-shared HMAC-SHA256 signature key used for validating .vax integrity before ingestion.
# Must be exactly 32 bytes, base64 encoded.
VAXDRIVE_HMAC_KEY=N1VZl2z0vsbyALw7NLizfUAi9UfELy9+dMwal7SwHBg=

# (Optional) The thumbprint of the EV Code Signing certificate to be used in build_release.ps1
CODE_SIGNING_THUMBPRINT=

# The pre-shared build key used for preparing USB drives.
# Must be exactly 32 bytes, base64 encoded.
VAXDRIVE_BUILD_KEY=dS7SumHE+wCoZwGeL6fBLyQ4twzIKwOJoISxoW7bgNw=
